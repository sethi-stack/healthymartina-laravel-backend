##
## HealthyMartina API — Production .env template
## Copy to .env on the Droplet and fill in real values.
## Generate APP_KEY with: php artisan key:generate --show
##

APP_NAME="HealthyMartina"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_TIMEZONE=Europe/Madrid
APP_URL=https://api.yourdomain.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Database (MySQL on same Droplet) ────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthymartina
DB_USERNAME=hmartina
DB_PASSWORD=STRONG_PASSWORD_HERE

# ── Sessions / Auth ─────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com

# Sanctum: comma-separated list of domains the React frontend runs on
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com,yourdomain.pages.dev

# ── CORS ────────────────────────────────────────────────────────
# Set to your Cloudflare Pages URL (and custom domain if you have one)
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourproject.pages.dev

# ── File storage (DigitalOcean Spaces) ──────────────────────────
FILESYSTEM_DISK=spaces
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=healthymartina
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# CDN URL (enable CDN in DO Spaces dashboard to get this):
DO_SPACES_URL=https://healthymartina.nyc3.cdn.digitaloceanspaces.com

# ── Cache / Queue ───────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ── Mail ────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="HealthyMartina"

# ── Stripe ──────────────────────────────────────────────────────
STRIPE_KEY=pk_live_...
STRIPE_SECRET=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
